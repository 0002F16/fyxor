{
  "name": "cv-tailor-mvp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cv-tailor/api",
    "dev:extension": "npm run dev -w @cv-tailor/extension",
    "build": "npm run build -w @cv-tailor/shared && npm run build -w @cv-tailor/api && npm run build -w @cv-tailor/extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
