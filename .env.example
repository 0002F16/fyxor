AI_PROVIDER=deepseek-api
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
# The runtime is hard-locked to DeepSeek. Groq/Gemini/OpenAI/Codex integrations
# have been removed; no other provider keys are read.
PORT=8787
# Bind host. 127.0.0.1 for local dev; 0.0.0.0 when behind a reverse proxy on the VPS.
HOST=127.0.0.1

# --- Accounts, cloud sync, usage (self-hosted) ---
# Postgres connection string. Matches docker-compose.yml for local dev.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/fyxor
# Better Auth signing secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Public base URL Better Auth runs at. On the VPS set this to the sslip.io URL.
BETTER_AUTH_URL=http://127.0.0.1:8787
# BETTER_AUTH_URL=https://api-76-13-177-250.sslip.io
# Optional free-tier cap on tailors per calendar month. 0 = unlimited.
FREE_MONTHLY_TAILORS=0
# Max simultaneous tailoring runs for one user; extra requests sit as "queued"
# until a slot frees. Default 3.
PER_USER_MAX_CONCURRENT_TAILORS=3
# Hard cap on simultaneous tailoring runs across all users on this VPS process
# (protects DeepSeek rate limits + CPU/memory). Default 6; tune against
# /health's `load` block and DeepSeek's rate limits.
GLOBAL_MAX_CONCURRENT_TAILORS=6

# --- Admin dashboard (served at /admin) ---
# Comma-separated allowlist of admin account emails. Any signed-in account whose
# email is listed here can reach the read-only admin dashboard. Empty = nobody.
ADMIN_EMAILS=johnyumul.ph@gmail.com
# Optional override for where the built admin SPA lives. Defaults to
# ../admin/dist relative to the API's working directory (apps/api).
# ADMIN_DIST=/srv/fyxor/apps/admin/dist
