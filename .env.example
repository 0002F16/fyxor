AI_PROVIDER=gemini-api
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# CODEX_PATH=codex
# CODEX_MODEL=
PORT=8787
# Bind host. 127.0.0.1 for local dev; 0.0.0.0 when behind a reverse proxy on the VPS.
HOST=127.0.0.1

# --- Accounts, cloud sync, usage (self-hosted) ---
# Postgres connection string. Matches docker-compose.yml for local dev.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/fyxor
# Better Auth signing secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Public base URL Better Auth runs at (your VPS domain in prod).
BETTER_AUTH_URL=http://127.0.0.1:8787
# Optional free-tier cap on tailors per calendar month. 0 = unlimited.
FREE_MONTHLY_TAILORS=0
