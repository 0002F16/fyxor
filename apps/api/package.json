{
  "name": "@cv-tailor/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run cv:css && tsc -p tsconfig.json",
    "cv:css": "cd ../.. && node_modules/.bin/tailwindcss -c apps/api/tailwind.cv.config.ts -i apps/api/cv.tailwind.css -o apps/api/src/cv.css --minify",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cv-tailor/shared": "0.1.0",
    "better-auth": "^1.6.19",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "mammoth": "^1.9.1",
    "openai": "^5.8.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "puppeteer": "^24.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "tsx": "^4.20.3"
  }
}
